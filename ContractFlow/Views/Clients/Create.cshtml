@using ContractMS.Models
@model Client
@{
    ViewData["Title"] = "Create Client";
}

<div class="container mt-4">
    <h1>Create New Client</h1>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Client Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter client name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ContactDetails" class="form-label">Contact Details</label>
                    <textarea asp-for="ContactDetails" class="form-control" rows="3" 
                              placeholder="Enter email, phone, address, etc."></textarea>
                    <span asp-validation-for="ContactDetails" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Region" class="form-label">Region</label>
                    <input asp-for="Region" class="form-control" placeholder="e.g., North America, Europe, Asia Pacific" />
                    <span asp-validation-for="Region" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Create Client
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@using ContractMS.Models
@model IEnumerable<Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Clients Management</h1>
        <a asp-action="Create" class="btn btn-success">Create New Client</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Contact Details</th>
                    <th>Region</th>
                    <th>Contracts</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td><strong>@client.Name</strong></td>
                        <td>@client.ContactDetails</td>
                        <td>@client.Region</td>
                        <td>
                            <span class="badge bg-info">@client.Contracts.Count contract(s)</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <form asp-action="Delete" asp-route-id="@client.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Are you sure you want to delete this client?')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <h5>No clients found</h5>
            <p>Create your first client to get started.</p>
        </div>
    }
</div>

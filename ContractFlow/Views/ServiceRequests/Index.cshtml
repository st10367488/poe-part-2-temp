@using ContractMS.Models
@model IEnumerable<ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Service Requests Management</h1>
        <a asp-action="Create" class="btn btn-success">Create New Service Request</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Contract</th>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Cost</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr>
                        <td>
                            <strong>@request.Contract?.ServiceLevel</strong>
                            <br />
                            <small class="text-muted">Contract #@request.ContractId</small>
                        </td>
                        <td>@request.Contract?.Client?.Name</td>
                        <td>@request.Description</td>
                        <td>@request.Cost.ToString("C")</td>
                        <td>
                            <span class="badge bg-@(request.Status switch {
                                ServiceRequestStatus.Completed => "success",
                                ServiceRequestStatus.InProgress => "primary",
                                ServiceRequestStatus.Pending => "warning",
                                ServiceRequestStatus.Cancelled => "danger",
                                _ => "secondary"
                            })">
                                @request.Status
                            </span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@request.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@request.Id" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Are you sure you want to delete this service request?')">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <h5>No service requests found</h5>
            <p>Create your first service request to get started.</p>
        </div>
    }
</div>

@using ContractMS.Models
@model ServiceRequest
@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="container mt-4">
    <h1>Edit Service Request</h1>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CostZAR" />

                <div class="mb-3">
                    <label asp-for="ContractId" class="form-label">Contract</label>
                    <select asp-for="ContractId" class="form-select" asp-items="ViewBag.Contracts">
                        <option value="">-- Select Contract --</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                    <div class="form-text">
                        <i class="bi bi-info-circle"></i> Only Active contracts are available for service requests.
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4" 
                              placeholder="Describe the service request details..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Cost" class="form-label">Cost (USD)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Cost" class="form-control" type="number" step="0.01" min="0" 
                               placeholder="0.00" id="costInput" />
                    </div>
                    <div class="form-text">
                        <small class="text-muted">ZAR Equivalent: <span id="zarEquivalent">R0.00</span></small>
                    </div>
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="@ServiceRequestStatus.Pending">Pending</option>
                        <option value="@ServiceRequestStatus.InProgress">In Progress</option>
                        <option value="@ServiceRequestStatus.Completed">Completed</option>
                        <option value="@ServiceRequestStatus.Cancelled">Cancelled</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function updateZar() {
            const usdAmount = parseFloat(document.getElementById('costInput').value) || 0;
            if (usdAmount > 0) {
                try {
                    // For demo purposes, using a fixed rate. In production, this would call an API
                    const exchangeRate = 18.50; // This would come from CurrencyService
                    const zarAmount = (usdAmount * exchangeRate).toFixed(2);
                    document.getElementById('zarEquivalent').textContent = 'R' + zarAmount;
                } catch (error) {
                    document.getElementById('zarEquivalent').textContent = 'Error calculating conversion';
                }
            } else {
                document.getElementById('zarEquivalent').textContent = 'R0.00';
            }
        }

        document.getElementById('costInput').addEventListener('input', updateZar);
        
        // Initial call to set the ZAR value on page load for the existing Cost
        updateZar();
    </script>
}

@using ContractMS.Models
@model IEnumerable<Contract>
@{
    ViewData["Title"] = "Contracts";
}

<div class="container mt-4">
    <h1>Contracts Management</h1>
    
    <!-- Search/Filter Form -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Search & Filter Contracts</h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Start Date From</label>
                    <input type="date" id="startDate" name="startDate" class="form-control" 
                           value="@ViewBag.StartDate" />
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">End Date To</label>
                    <input type="date" id="endDate" name="endDate" class="form-control" 
                           value="@ViewBag.EndDate" />
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="">All Statuses</option>
                        @{
    var statuses = (ContractStatus[])ViewBag.Statuses;
}
@foreach (ContractStatus status in statuses)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Filter</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Contracts List</h4>
        <a asp-action="Create" class="btn btn-success">Create New Contract</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Client</th>
                    <th>Service Level</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Agreement</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model)
                {
                    <tr>
                        <td>@contract.Client?.Name</td>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge bg-@(contract.Status switch {
                                ContractStatus.Active => "success",
                                ContractStatus.Draft => "secondary",
                                ContractStatus.Expired => "danger",
                                ContractStatus.OnHold => "warning",
                                _ => "secondary"
                            })">
                                @contract.Status
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                            {
                                <a href="@contract.SignedAgreementPath" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-file-pdf"></i> View PDF
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">No file</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@contract.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@contract.Id" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Are you sure you want to delete this contract?')">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <h5>No contracts found</h5>
            <p>Try adjusting your search criteria or create a new contract.</p>
        </div>
    }
</div>
